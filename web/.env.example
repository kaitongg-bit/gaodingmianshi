# 密钥必须与变量名在同一行，中间不能换行；保存文件后重启 npm run dev
GEMINI_API_KEY=

# 可选
GEMINI_MODEL=gemini-2.0-flash

# Supabase — 应用连接（Dashboard → Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=
# 新控制台 publishable 或旧控制台 anon JWT 二选一即可：
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 仅服务端脚本/Webhook；勿用 NEXT_PUBLIC_；勿提交真实值
# 反馈自动赠分 + 后台记账依赖 service role：
# SUPABASE_SERVICE_ROLE_KEY=

# 反馈提交后邮件通知（Resend）；不配则仅写库 + 可选赠分
# RESEND_API_KEY=
# SUPPORT_NOTIFY_EMAIL=you@example.com
# 需先在 Resend 验证发件域名；未验证时可试用 Resend 提供的 onboarding 发件地址：
# RESEND_FROM_EMAIL=DraftReady <onboarding@resend.dev>

# 以下为 Postgres 直连（psql / SQL Editor），不要写进 Next 前端：
# DATABASE_URL=postgresql://postgres:密码@db.xxx.supabase.co:5432/postgres

# 可选：Microsoft Clarity 项目 ID（仅前端；不设则默认 w67f77050w；设为空可关闭 Clarity）
# NEXT_PUBLIC_CLARITY_PROJECT_ID=w67f77050w
