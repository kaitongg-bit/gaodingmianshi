# 密钥必须与变量名在同一行，中间不能换行；保存文件后重启 npm run dev
GEMINI_API_KEY=

# 可选
GEMINI_MODEL=gemini-2.0-flash

# Supabase — 应用连接（Dashboard → Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=
# 新控制台 publishable 或旧控制台 anon JWT 二选一即可：
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 仅服务端脚本/Webhook；勿用 NEXT_PUBLIC_；勿提交真实值
# SUPABASE_SERVICE_ROLE_KEY=

# 以下为 Postgres 直连（psql / SQL Editor），不要写进 Next 前端：
# DATABASE_URL=postgresql://postgres:密码@db.xxx.supabase.co:5432/postgres

# 可选：Microsoft Clarity 项目 ID（仅前端；未设置时仍向 dataLayer 推事件，便于以后接 GTM）
# NEXT_PUBLIC_CLARITY_PROJECT_ID=
